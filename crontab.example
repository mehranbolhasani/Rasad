# Rasad — example cron: rebuild site every hour
# Install: crontab -e and paste the line below (adjust path and log).
# Tip: set up logrotate for /var/log/rasad.log so it does not grow unbounded.
# Note: auto-pulls code before building. Safe only if working tree is clean.

# Every 60 minutes
0 * * * * cd /path/to/Rasad && git pull --ff-only origin main && .venv/bin/python build.py --config config.yaml >> /var/log/rasad.log 2>&1

# Optional: every 15 minutes
# */15 * * * * cd /path/to/Rasad && git pull --ff-only origin main && .venv/bin/python build.py --config config.yaml >> /var/log/rasad.log 2>&1
