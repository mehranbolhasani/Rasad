# Rasad — example cron: rebuild site every hour
# Install: crontab -e and paste the line below (adjust path and log).

# Every 60 minutes
0 * * * * cd /path/to/Rasad && .venv/bin/python bridge_build.py --config config.yaml --with-build >> /var/log/rasad.log 2>&1

# Optional: every 15 minutes
# */15 * * * * cd /path/to/Rasad && .venv/bin/python bridge_build.py --config config.yaml --with-build >> /var/log/rasad.log 2>&1
